# Agent Flow Cloud Mode Configuration
# Copy this to .env.local and fill in your values

# Supabase Configuration (get from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Channel Token (generate a random string, use the same in your local hook setup)
AGENT_FLOW_CHANNEL_TOKEN=your-secret-token
NEXT_PUBLIC_AGENT_FLOW_CHANNEL_TOKEN=your-secret-token

# Local Development (set to 0 for real events, 1 for demo mode)
NEXT_PUBLIC_DEMO=0
NEXT_PUBLIC_RELAY_PORT=3001
